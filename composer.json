{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "larva/laravel-skel-pro",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework",
        "kit",
        "skel",
        "skeleton",
        "api"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "intervention/image-laravel": "^1.5",
        "jenssegers/agent": "^2.6",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.46",
        "laravel/octane": "^2.15",
        "laravel/pulse": "^1.7",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^11.1",
        "laravel/telescope": "^5.20",
        "laravel/tinker": "^2.10.1",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1",
        "overtrue/easy-sms": "^3.2",
        "predis/predis": "^3.4",
        "zhuzhichao/ip-location-zh": "^2.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^2.3",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.29",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.55"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "bootstrap/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.develop', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "@php artisan storage:link",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "vendor/bin/pint --config pint.json"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.develop', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi",
            "@php artisan storage:link --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "check-style": "vendor/bin/pint --config pint.json --test",
        "fix-style": "vendor/bin/pint --config pint.json"
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "autoloader-suffix": "_skel",
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "ignore": [
                "GHSA-qrr6-mg7r-m243",
                "PKSA-5jz8-6tcw-pbk4"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}